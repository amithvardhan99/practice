   "source": [
    "def maxSum(nums,l,r):\n",
    "    m = (l + r) // 2\n",
    "    if l == r:\n",
    "        return nums[l]\n",
    "    \n",
    "    max_num = max(maxSum(nums,l,m),maxSum(nums,m+1,r),maxCrossingSum(nums,l,m,r))\n",
    "    return max_num"
   ]
  },
